---
import NewsletterForm from "./newsletterForm.astro";
---

<div class="text-center lg:text-left">

    <p class="mb-4 text-xs font-medium uppercase tracking-[0.3em] text-accent-dot md:text-sm">
        Novedades
    </p>

    <h2 class="font-[Montserrat] text-3xl font-extrabold leading-tight text-text md:text-5xl">
        Enterate de las novedades de vera
    </h2>

    <p class="mt-6 text-base leading-relaxed text-text/60 md:text-lg">
        Recibí actualizaciones sobre nuevas funciones, mejoras y próximos lanzamientos de la aplicación.
    </p>

    <NewsletterForm />

    <p class="mt-4 text-[10px] text-text/40 md:text-xs">
        Sin spam. Solo novedades importantes de la aplicación.
    </p>

</div>