<header
        class="fixed top-0 z-50 w-full border-b border-white/10 bg-[#050816]/80 backdrop-blur-xl"
>
    <div
            class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4 lg:px-20"
    >
        <!-- Logo -->
        <div class="flex items-center gap-3">
            <img src="/logo.png" alt="VERA" class="w-10" />

            <span
                    class="bg-gradient-to-r from-blue-400 to-indigo-500 bg-clip-text font-[Montserrat] text-xl font-bold text-transparent"
            >
        VERA
      </span>
        </div>

        <!-- Desktop Nav -->
        <nav class="hidden items-center gap-8 md:flex">
            <a href="#" class="text-slate-300 transition hover:text-white">
                Inicio
            </a>

            <a
                    href="#features"
                    class="text-slate-300 transition hover:text-white"
            >
                Funciones
            </a>

            <a
                    href="#comparative"
                    class="text-slate-300 transition hover:text-white"
            >
                Comparativa
            </a>

            <a
                    href="#download"
                    class="rounded-xl bg-gradient-to-r from-[#0056db] to-[#1800ad] px-5 py-3 font-medium transition duration-300 hover:scale-105"
            >
                Comenzar
            </a>
        </nav>

        <!-- Mobile Toggle -->
        <button
                id="menu-btn"
                class="flex h-11 w-11 items-center justify-center rounded-2xl border border-white/10 bg-white/5 text-lg backdrop-blur-md transition duration-300 hover:bg-white/10 md:hidden"
        >
            ☰
        </button>
    </div>

    <!-- Mobile Menu -->
    <div
            id="mobile-menu"
            class="hidden border-t border-white/10 bg-[#050816]/95 px-6 py-6 backdrop-blur-2xl md:hidden"
    >
        <div class="grid grid-cols-2 gap-4">
            <!-- Inicio -->
            <a
                    href="#"
                    class="group rounded-[1.5rem] border border-white/10 bg-white/5 p-5 transition duration-300 hover:border-blue-500/30 hover:bg-blue-500/10"
            >
                <div
                        class="mb-4 flex h-12 w-12 items-center justify-center rounded-2xl bg-gradient-to-r from-[#0056db] to-[#1800ad] text-xl"
                >
                    🏠
                </div>

                <h3 class="font-semibold">
                    Inicio
                </h3>

                <p class="mt-2 text-sm text-slate-400">
                    Volver al inicio
                </p>
            </a>

            <!-- Features -->
            <a
                    href="#features"
                    class="group rounded-[1.5rem] border border-white/10 bg-white/5 p-5 transition duration-300 hover:border-blue-500/30 hover:bg-blue-500/10"
            >
                <div
                        class="mb-4 flex h-12 w-12 items-center justify-center rounded-2xl bg-gradient-to-r from-[#0056db] to-[#1800ad] text-xl"
                >
                    ⚙️
                </div>

                <h3 class="font-semibold">
                    Funciones
                </h3>

                <p class="mt-2 text-sm text-slate-400">
                    Cómo funciona VERA
                </p>
            </a>

            <!-- Comenzar -->
            <a
                    href="#download"
                    class="group rounded-[1.5rem] border border-white/10 bg-gradient-to-r from-[#0056db]/20 to-[#1800ad]/20 p-5 transition duration-300 hover:scale-[1.02]"
            >
                <div
                        class="mb-4 flex h-12 w-12 items-center justify-center rounded-2xl bg-gradient-to-r from-[#0056db] to-[#1800ad] text-xl"
                >
                    🚀
                </div>

                <h3 class="font-semibold">
                    Comenzar
                </h3>

                <p class="mt-2 text-sm text-slate-300">
                    Probar experiencia
                </p>
            </a>

            <!-- Comparativa -->
            <a
                    href="#comparative"
                    class="group rounded-[1.5rem] border border-white/10 bg-white/5 p-5 transition duration-300 hover:border-blue-500/30 hover:bg-blue-500/10"
            >
                <div
                        class="mb-4 flex h-12 w-12 items-center justify-center rounded-2xl bg-gradient-to-r from-[#0056db] to-[#1800ad] text-xl"
                >
                    📊
                </div>

                <h3 class="font-semibold">
                    Comparativa
                </h3>

                <p class="mt-2 text-sm text-slate-400">
                    Antivirus vs VERA
                </p>
            </a>
        </div>
    </div>
</header>

<script>
    const menuBtn = document.getElementById("menu-btn");
    const mobileMenu = document.getElementById("mobile-menu");

    if (menuBtn && mobileMenu) {
        menuBtn.addEventListener("click", () => {
            mobileMenu.classList.toggle("hidden");

            if (mobileMenu.classList.contains("hidden")) {
                menuBtn.innerHTML = "☰";
            } else {
                menuBtn.innerHTML = "✕";
            }
        });

        // Auto close on link click
        const mobileLinks = mobileMenu.querySelectorAll("a");

        mobileLinks.forEach((link) => {
            link.addEventListener("click", () => {
                mobileMenu.classList.add("hidden");
                menuBtn.innerHTML = "☰";
            });
        });
    }
</script>