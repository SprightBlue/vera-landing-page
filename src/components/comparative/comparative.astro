---
import ComparativeHeader from "./comparativeHeader.astro";
import ComparativeGrid from "./comparativeGrid.astro";
import ComparativeHook from "./comparativeHook.astro";

const antivirus = [
    "Protección contra malware y virus conocidos",
    "Escaneo de archivos y descargas en el sistema",
    "Defensa en tiempo real ante software malicioso",
    "Actualizaciones de seguridad automáticas",
];

const vera = [
    "Detecta phishing y estafas conversacionales",
    "Analiza mensajes en tiempo real",
    "Previene ingeniería social y manipulación digital",
    "Evalúa el riesgo antes de interactuar",
];
---

<section
        id="comparative"
        class="relative overflow-hidden px-6 py-(--section-py-mobile) lg:py-(--section-py-desktop)"
>

    <div class="absolute left-1/2 top-1/2 -z-10 h-125 w-125 -translate-x-1/2 -translate-y-1/2 rounded-full bg-section-glow blur-[120px]"></div>

    <div class="relative mx-auto max-w-7xl">

        <ComparativeHeader />

        <ComparativeGrid
                antivirus={antivirus}
                vera={vera}
        />

        <ComparativeHook />

    </div>

</section>