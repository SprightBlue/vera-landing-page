---
const { step } = Astro.props;
---

<div class="group relative overflow-hidden rounded-(--radius-3xl) border border-(--glass-border) bg-(--glass-bg) p-8 backdrop-blur-xl transition-all duration-(--transition-base) hover:-translate-y-2 hover:border-(--glass-border-hover)">

    <span class="absolute -right-2 -top-4 text-8xl font-black leading-none text-text/5 select-none transition-all duration-(--transition-base) group-hover:text-text/10 group-hover:-translate-y-1">
        {step.number}
    </span>

    <div class="relative z-10">

        <div class="flex items-start justify-between gap-4">
            <h3 class="max-w-[80%] text-xl font-bold text-text md:text-2xl">
                {step.title}
            </h3>
        </div>

        <p class="mt-4 leading-relaxed text-text/60 group-hover:text-text/80 transition-colors duration-(--transition-base)">
            {step.description}
        </p>

    </div>

</div>