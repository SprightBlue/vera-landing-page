<div class="flex flex-wrap items-center justify-center gap-4 lg:justify-start min-h-14">
    <a
            href="javascript:void(0);"
            id="btn-hero-google-play"
            class="group transition-all duration-300 hover:-translate-y-1 hover:brightness-110 active:translate-y-0 outline-none will-change-transform"
    >
        <img
                src="/badges/google-play.svg"
                alt="Google Play"
                width="190"
                height="56"
                class="object-contain w-41.25 h-12 lg:w-47.5 lg:h-14"
        />
    </a>

    <a
            href="javascript:void(0);"
            id="btn-hero-web-app"
            class="group inline-flex items-center justify-center gap-3 bg-black border border-white/40 rounded-xl w-41.25 h-12 lg:w-47.5 lg:h-14 transition-all duration-300 hover:-translate-y-1 hover:border-white hover:shadow-xl hover:shadow-primary/5 active:translate-y-0 outline-none will-change-transform"
    >
        <span class="material-icons-round text-white/80 text-[22px] lg:text-[26px]">
            public
        </span>

        <div class="flex flex-col text-left leading-tight">
            <span class="text-[8px] lg:text-[9px] uppercase font-bold tracking-widest text-white/50">Acceder a la</span>
            <span class="text-[13px] lg:text-[15px] font-black uppercase text-white tracking-tight">Versión Web</span>
        </div>
    </a>
</div>

<script is:inline>
    (function() {
        const trackHero = (store) => {
            if (typeof gtag === 'function') {
                gtag('event', 'hero_cta_click', {
                    'store_name': store,
                    'event_category': 'conversion'
                });
            }
        };

        document.addEventListener('click', (e) => {
            if (e.target.closest('#btn-hero-google-play')) trackHero('google_play');
            if (e.target.closest('#btn-hero-web-app')) trackHero('web_version');
        });
    })();
</script>