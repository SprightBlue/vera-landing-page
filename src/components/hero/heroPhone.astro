---
import HeroChat from "./heroChat.astro";
---

<div class="relative flex w-full justify-center">

    <div class="absolute inset-0 flex items-center justify-center -z-10">
        <div class="h-72 w-72 rounded-full bg-phone-glow blur-3xl sm:h-96 sm:w-96"></div>
    </div>

    <div class="relative w-full rounded-(--radius-3xl) border border-(--glass-border) bg-bg/40 p-3 shadow-2xl backdrop-blur-xl transition-all duration-500 hover:border-white/20"
         class:list={[
             "max-w-(--phone-w-sm)",
             "sm:max-w-(--phone-w-lg)"
         ]}>

        <div class="mb-4 flex justify-center">
            <div class="h-1.5 rounded-full bg-white/10 w-(--phone-bar-w)"></div>
        </div>

        <div class="relative overflow-hidden rounded-[calc(var(--radius-3xl)-0.75rem)]">
            <HeroChat />
        </div>

    </div>

</div>