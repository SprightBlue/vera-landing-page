---
import HeroChat from "./heroChat.astro";
---

<div class="relative flex w-full justify-center">

    <!-- Glow -->
    <div class="absolute inset-0 flex items-center justify-center">

        <div class="h-72 w-72 rounded-full bg-indigo-500/10 blur-3xl sm:h-96 sm:w-96"></div>

    </div>

    <!-- Phone -->
    <div class="relative w-full max-w-[340px] rounded-(--radius-3xl) border border-(--glass-border) bg-bg/40 p-3 shadow-2xl backdrop-blur-xl sm:max-w-[360px]">

        <!-- Top bar -->
        <div class="mb-3 flex justify-center">

            <div class="h-1.5 w-24 rounded-full bg-white/10"></div>

        </div>

        <HeroChat />

    </div>

</div>