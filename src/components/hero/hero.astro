---
import HeroBadges from "@/components/hero/heroBadges.astro";
const heroImageUrl = "/images/hero-image.jpg";
---

<section id="hero" class="relative overflow-hidden py-20 lg:py-32 min-h-[85vh] flex items-center">

    <div
            class="absolute inset-0 z-0
               after:absolute after:inset-0 after:bg-linear-to-r after:from-bg after:via-bg/40 after:to-transparent
               before:absolute before:inset-x-0 before:bottom-0 before:h-64 before:bg-linear-to-t before:from-bg before:via-bg/80 before:to-transparent before:z-10"
            aria-hidden="true"
    >
        <img
                src={heroImageUrl}
                alt=""
                role="presentation"
                fetchpriority="high"
                width= auto
                height= auto
                class="w-full h-full object-cover object-center lg:object-[right_25%] opacity-70"
        />
    </div>

    <div class="relative z-10 mx-auto max-w-7xl px-6 lg:px-12 w-full">
        <div class="grid grid-cols-1 lg:grid-cols-12 items-center">

            <div class="lg:col-span-7 space-y-6 md:space-y-8 text-center lg:text-left">
                <h1 class="text-4xl font-display font-extrabold leading-[1.1] text-white lg:text-6xl tracking-tight text-balance">
                    <span class="bg-linear-to-r from-primary to-secondary bg-clip-text text-transparent inline-block">
                        Tu Asistente
                    </span> Inteligente contra Estafas
                </h1>

                <p class="mx-auto max-w-lg text-lg text-white/80 lg:mx-0 lg:max-w-xl lg:text-xl text-pretty font-medium">
                    Vera analiza mensajes, identifica links sospechosos y te guía para tomar decisiones seguras online. Sin jerga técnica, solo protección clara y simple.
                </p>

                <div class="pt-4 flex justify-center lg:justify-start">
                    <HeroBadges />
                </div>
            </div>

        </div>
    </div>
</section>