---
import HeroStores from "./heroStores.astro";
---

<div class="space-y-8 text-center lg:text-left">

    <div class="inline-flex max-w-full items-center gap-3 rounded-full border border-(--glass-border) bg-(--glass-bg) px-4 py-2 text-sm text-text/70 backdrop-blur-md">

        <span class="h-2 w-2 shrink-0 rounded-full bg-accent-dot shadow-[0_0_10px_rgba(59,130,246,0.5)]"></span>

        <span class="truncate font-medium tracking-wide">
            Asistente contra estafas digitales
        </span>

    </div>

    <h1 class="font-[Montserrat] text-4xl font-extrabold leading-[1.1] text-text sm:text-6xl lg:text-7xl">
        Llevá a vera contigo
    </h1>

    <p class="mx-auto max-w-xl text-lg leading-relaxed text-text/60 lg:mx-0 lg:text-xl">
        Tu asistente proactivo que analiza mensajes y detecta amenazas digitales antes de que tomes una decisión riesgosa.
    </p>

    <div class="pt-4">
        <HeroStores />
    </div>

</div>