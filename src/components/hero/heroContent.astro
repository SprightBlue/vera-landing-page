---
import HeroStores from "./heroStores.astro";
---

<div class="space-y-6 text-center lg:text-left">

    <!-- Badge -->
    <div class="inline-flex max-w-full items-center gap-3 rounded-full border border-(--glass-border) bg-(--glass-bg) px-4 py-2 text-sm text-text/70 backdrop-blur-md">

        <span class="h-2 w-2 shrink-0 rounded-full bg-blue-500"></span>

        <span class="truncate">
            Asistente contra estafas digitales
        </span>

    </div>

    <!-- Title -->
    <h1 class="font-[Montserrat] text-4xl font-extrabold leading-tight text-text sm:text-5xl lg:text-6xl">
        Llevá a vera contigo
    </h1>

    <!-- Description -->
    <p class="mx-auto max-w-xl text-base leading-relaxed text-text/60 sm:text-lg lg:mx-0">
        Tu asistente proactivo que analiza mensajes y detecta amenazas digitales antes de que tomes una decisión riesgosa.
    </p>

    <HeroStores />

</div>