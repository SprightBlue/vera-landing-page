<div class="flex flex-wrap items-center justify-center gap-4 lg:justify-start min-h-14">

    <a
            href="javascript:void(0);"
            id="btn-google-play"
            class="inline-block transition-all duration-300 hover:opacity-80 active:opacity-60 active:translate-y-0.5 focus:outline-none focus:ring-2 focus:ring-primary/50 rounded-lg"
            aria-label="Descargar en Google Play"
    >
        <img
                src="/badges/google-play.svg"
                alt="Google Play"
                width="190"
                height="56"
                loading="eager"
                class="object-contain w-41.25 h-12 lg:w-47.5 lg:h-14"
        />
    </a>

    <a
            href="javascript:void(0);"
            id="btn-web-app"
            class="inline-flex items-center justify-center gap-3 bg-black text-white border border-white/70 rounded-lg w-41.25 h-12 lg:w-47.5 lg:h-14 transition-all duration-300 hover:opacity-80 active:opacity-60 active:translate-y-0.5 box-border focus:outline-none focus:ring-2 focus:ring-white/50"
            aria-label="Ir a la versión web"
    >
        <span class="material-icons-round text-[20px] lg:text-[24px]" aria-hidden="true">public</span>

        <div class="flex flex-col items-start leading-[1.1] text-left">
            <span class="text-[9px] lg:text-[10px] uppercase font-medium tracking-wider opacity-70">Acceder a la</span>
            <span class="text-[13px] lg:text-[15px] font-bold whitespace-nowrap uppercase text-white">Versión Web</span>
        </div>
    </a>

</div>

<script is:inline>
    const trackBadgeClick = (storeName) => {
        if (typeof gtag === 'function') {
            gtag('event', 'click_cta', {
                'store_name': storeName,
                'event_category': 'conversion',
                'event_label': 'CTA Click'
            });
        }
    };

    document.getElementById('btn-google-play')?.addEventListener('click', () => trackBadgeClick('google_play'));
    document.getElementById('btn-web-app')?.addEventListener('click', () => trackBadgeClick('web_version'));
</script>