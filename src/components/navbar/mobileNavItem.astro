---
interface Props {
    href: string;
    title: string;
    description: string;
    icon: string;
}

const { href, title, description, icon } = Astro.props;
---

<a
        href={href}
        class="group flex items-center justify-between w-full rounded-xl border border-(--glass-border) bg-(--glass-bg) p-4 sm:p-5 transition-all duration-(--transition-base) active:scale-[0.98] active:bg-(--glass-border-hover)"
>

    <div class="flex flex-col gap-0.5 overflow-hidden min-w-0">
        <p class="text-sm font-bold tracking-tight text-text truncate">
            {title}
        </p>
        <p class="text-[9px] leading-none tracking-widest text-text/30 uppercase font-medium truncate">
            {description}
        </p>
    </div>

    <div class="flex shrink-0 items-center justify-center pl-3">
        <span class="material-icons-round text-xl sm:text-2xl text-text/20 group-hover:text-accent-dot transition-colors">
            {icon}
        </span>
    </div>
</a>