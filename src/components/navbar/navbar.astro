---
import DesktopNav from "./desktopNav.astro";
import MobileNav from "./mobileNav.astro";

const isotipoSrc = "/brand/isologo-vera.png";
const logotipoSrc = "/brand/nombre-vera.png";
---

<header class="fixed top-0 z-50 w-full border-b border-white/10 bg-bg/80 backdrop-blur-md">
    <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-3 lg:px-12">

        <div class="flex items-center">
            <a href="#hero" class="group flex items-center gap-3 h-10 lg:h-12 transition-opacity hover:opacity-80">
                <img
                        src={isotipoSrc}
                        alt="Vera Isotipo"
                        class="h-full w-auto object-contain select-none opacity-90"
                        width="48"
                        height="48"
                />
                <img
                        src={logotipoSrc}
                        alt="Vera Logotipo"
                        class="h-[75%] w-auto object-contain select-none opacity-90"
                        width="120"
                        height="40"
                />
            </a>
        </div>

        <DesktopNav />

        <button
                id="menu-btn"
                class="group flex size-11 items-center justify-center rounded-xl border border-white/10 bg-white/5 text-white md:hidden hover:bg-white/10 transition-all active:scale-95 outline-none"
                aria-label="Menú"
        >
            <span id="menu-icon-container" class="material-icons-round text-2xl transition-all duration-200 ease-out">
                menu
            </span>
        </button>

    </div>

    <MobileNav />
</header>

<script is:inline>
    (function() {
        const menuBtn = document.getElementById("menu-btn");
        const iconContainer = document.getElementById("menu-icon-container");
        const mobileMenu = document.getElementById("mobile-menu");

        const toggleMenu = (forceClose = false) => {
            const isMenuOpen = !mobileMenu.classList.contains("hidden");

            iconContainer.style.opacity = "0";
            iconContainer.style.transform = "scale(0.8)";

            setTimeout(() => {
                if (isMenuOpen || forceClose) {
                    mobileMenu.classList.add("hidden");
                    iconContainer.textContent = "menu";
                } else {
                    mobileMenu.classList.remove("hidden");
                    iconContainer.textContent = "close";
                }

                iconContainer.style.opacity = "1";
                iconContainer.style.transform = "scale(1)";
            }, 150);
        };

        if (menuBtn && mobileMenu && iconContainer) {
            menuBtn.addEventListener("click", (e) => {
                e.stopPropagation();
                toggleMenu();
            });

            mobileMenu.addEventListener("click", (e) => {
                if (e.target.closest('a')) toggleMenu(true);
            });
        }

        //google analytics tracking
        const trackNav = (eventLabel, origin) => {
            if (typeof gtag === 'function') {
                gtag('event', 'get_started_click', {
                    'event_category': 'conversion',
                    'event_label': eventLabel,
                    'nav_origin': origin
                });
            }
        };

        document.addEventListener('click', (e) => {
            const desktopBtn = e.target.closest('#desktop-start-btn');
            const mobileBtn = e.target.closest('#mobile-start-btn');

            if (desktopBtn) trackNav('Desktop Navigation', 'desktop');
            if (mobileBtn) trackNav('Mobile Menu', 'mobile');
        });
    })();
</script>