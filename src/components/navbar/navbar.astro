---
import DesktopNav from "./desktopNav.astro";
import MobileMenu from "./mobileMenu.astro";
---

<header class="fixed top-0 z-50 w-full border-b border-(--glass-border) bg-bg/80 backdrop-blur-xl">

    <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4 lg:px-(--spacing-grid-gap-desktop)">

        <div class="flex items-center gap-3">
            <img src="/logo.png" alt="vera" class="w-10 select-none" />

            <span class="bg-linear-to-r from-blue-500 to-indigo-500 bg-clip-text font-[Montserrat] text-4xl font-bold text-transparent tracking-tight">
                vera
            </span>
        </div>

        <DesktopNav />

        <button
                id="menu-btn"
                class="flex h-11 w-11 items-center justify-center rounded-xl border border-(--glass-border) bg-(--glass-bg) text-text backdrop-blur-md transition-all active:scale-95 md:hidden"
        >
            <span class="material-icons-round text-xl">menu</span>
        </button>

    </div>

    <MobileMenu />

</header>

<script>
    const menuBtn = document.getElementById("menu-btn");
    const mobileMenu = document.getElementById("mobile-menu");

    if (menuBtn instanceof HTMLButtonElement && mobileMenu instanceof HTMLElement) {
        const icon = menuBtn.querySelector("span");

        menuBtn.addEventListener("click", () => {
            mobileMenu.classList.toggle("hidden");

            const isOpen = !mobileMenu.classList.contains("hidden");

            if (icon instanceof HTMLElement) {
                icon.textContent = isOpen ? "close" : "menu";
            }
        });

        // Cerrar menú al hacer clic en un link
        mobileMenu.querySelectorAll("a").forEach((link) => {
            link.addEventListener("click", () => {
                mobileMenu.classList.add("hidden");

                if (icon instanceof HTMLElement) {
                    icon.textContent = "menu";
                }
            });
        });
    }
</script>