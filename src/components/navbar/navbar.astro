---
import DesktopNav from "./desktopNav.astro";
import MobileMenu from "./mobileMenu.astro";
---

<header class="fixed top-0 z-50 w-full border-b border-white/10 bg-(--color-bg)/80 backdrop-blur-xl">

    <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4 lg:px-20">

        <!-- Logo -->
        <div class="flex items-center gap-3">
            <img src="/logo.png" alt="vera" class="w-10" />

            <span class="bg-gradient-to-r from-blue-500 to-indigo-500 bg-clip-text font-[Montserrat] text-4xl font-bold text-transparent">
        vera
      </span>
        </div>

        <DesktopNav />

        <!-- Mobile Button -->
        <button
                id="menu-btn"
                class="flex h-11 w-11 items-center justify-center rounded-2xl border border-white/10 bg-white/5 text-(--color-text) backdrop-blur-md md:hidden"
        >
            <span class="material-icons-round text-xl">menu</span>
        </button>

    </div>

    <MobileMenu />

</header>

<script>
    const menuBtn = document.getElementById("menu-btn");
    const mobileMenu = document.getElementById("mobile-menu");

    if (menuBtn instanceof HTMLButtonElement && mobileMenu instanceof HTMLElement) {
        const icon = menuBtn.querySelector("span");

        menuBtn.addEventListener("click", () => {
            mobileMenu.classList.toggle("hidden");

            const isOpen = !mobileMenu.classList.contains("hidden");

            if (icon instanceof HTMLElement) {
                icon.textContent = isOpen ? "close" : "menu";
            }
        });

        mobileMenu.querySelectorAll("a").forEach((link) => {
            link.addEventListener("click", () => {
                mobileMenu.classList.add("hidden");

                if (icon instanceof HTMLElement) {
                    icon.textContent = "menu";
                }
            });
        });
    }
</script>