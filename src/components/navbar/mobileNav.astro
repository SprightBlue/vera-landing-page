---
const navLinks = [
    { href: "#risks", label: "Riesgos Digitales" },
    { href: "#mobile", label: "En tu Celular" },
    { href: "#web", label: "Funciones Web" },
];
---

<nav id="mobile-menu" class="hidden border-t border-white/10 bg-bg/95 backdrop-blur-xl px-6 py-8 md:hidden">
    <div class="grid grid-cols-2 gap-3">
        {navLinks.map(({ href, label }) => (
                <a
                        href={href}
                        class="flex items-center justify-center rounded-xl border border-white/10 bg-white/5 p-4 text-sm font-bold tracking-tight text-white transition-all active:scale-95 active:bg-white/10 outline-none"
                >
                    {label}
                </a>
        ))}

        <a
                id="mobile-start-btn"
                href="#cta"
                class="flex items-center justify-center rounded-xl border border-primary/30 bg-primary/10 p-4 text-sm font-bold tracking-tight text-primary-light transition-all active:scale-95 active:bg-primary/20 outline-none"
        >
            Protegerse Ahora
        </a>
    </div>
</nav>