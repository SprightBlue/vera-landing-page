---
const navLinks = [
    { href: "#danger", label: "Riesgos Digitales" },
    { href: "#phone", label: "En tu Celular" },
    { href: "#web", label: "En tu Navegador" },
];
---

<nav id="mobile-menu" class="hidden border-t border-white/10 bg-bg/95 backdrop-blur-xl px-6 py-8 md:hidden">
    <div class="grid grid-cols-2 gap-3">
        {
            navLinks.map(({ href, label }) => (
                    <a
                            href={href}
                            class="flex items-center justify-center rounded-xl border border-white/10 bg-white/5 p-4 text-sm font-bold tracking-tight text-white transition-colors active:scale-[0.98] active:bg-white/10"
                    >
                        {label}
                    </a>
            ))
        }

        <a
                id="mobile-start-btn"
                href="#cta"
                class="flex items-center justify-center rounded-xl border border-indigo-400/30 bg-indigo-500/10 p-4 text-sm font-bold tracking-tight text-indigo-100 transition-colors active:scale-[0.98] active:bg-indigo-500/20"
        >
            Comenzar
        </a>
    </div>
</nav>

<script is:inline>
    const startBtn = document.getElementById('mobile-start-btn');

    if (startBtn) {
        startBtn.addEventListener('click', () => {
            if (typeof window.gtag !== 'undefined') {
                window.gtag('event', 'mobile_get_started_click', {
                    'event_category': 'conversion',
                    'event_label': 'Mobile Menu'
                });
            }
        });
    }
</script>