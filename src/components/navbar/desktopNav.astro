---
const navLinks = [
    { href: "#problem", label: "El Peligro" },
    { href: "#phone", label: "En el Celular" },
    { href: "#web", label: "En la Computadora" },
];
---

<nav class="hidden items-center gap-8 md:flex">
    {navLinks.map(({ href, label }) => (
            <a
                    href={href}
                    class="group relative py-1 text-sm font-medium text-white/60 transition-colors hover:text-white"
            >
                {label}
                <span class="absolute inset-x-0 bottom-0 h-px w-0 bg-white/40 transition-all duration-300 group-hover:w-full"></span>
            </a>
    ))}

    <a
            id="desktop-start-btn"
            href="#cta"
            class="inline-flex items-center justify-center px-5 py-2.5 rounded-xl border border-indigo-400/30 bg-indigo-500/10 text-indigo-100 text-sm font-bold transition-colors hover:bg-indigo-500/20 hover:border-indigo-400/50"
    >
        Comenzar
    </a>
</nav>

<script is:inline>
    const startBtn = document.getElementById('desktop-start-btn');

    if (startBtn) {
        startBtn.addEventListener('click', () => {
            if (typeof window.gtag !== 'undefined') {
                window.gtag('event', 'desktop_get_started_click', {
                    'event_category': 'conversion',
                    'event_label': 'Desktop Navigation'
                });
            }
        });
    }
</script>