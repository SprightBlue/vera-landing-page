---
const navLinks = [
    { href: "#risks", label: "Riesgos" },
    { href: "#mobile", label: "App Móvil" },
    { href: "#web", label: "Gestión Web" },
];
---

<nav class="hidden items-center gap-8 md:flex">
    {navLinks.map(({ href, label }) => (
            <a
                    href={href}
                    class="relative py-1 text-sm font-medium text-white/60 transition-colors hover:text-white
                   after:absolute after:bottom-0 after:left-0 after:h-px after:w-0 after:bg-white/40 after:transition-all after:duration-300 hover:after:w-full"
            >
                {label}
            </a>
    ))}

    <a
            id="desktop-start-btn"
            href="#cta"
            class="inline-flex items-center justify-center px-5 py-2.5 rounded-xl border border-primary/30 bg-primary/10 text-primary-light text-sm font-bold transition-all duration-300 hover:bg-primary/20 hover:border-primary/50 outline-none active:scale-95"
    >
        Probar Vera
    </a>
</nav>