---
interface Props {
    href: string;
    icon: string;
    title: string;
}

const { href, icon, title } = Astro.props;

const isAction = title.toLowerCase().includes("comenzar");
---

<a
        href={href}
        class:list={[
            "flex items-center gap-4 w-full rounded-xl border p-4 sm:p-5 transition-colors",
            {
            "border-white/10 bg-white/3": !isAction,
            "border-indigo-400/30 bg-indigo-500/10 hover:bg-indigo-500/15": isAction
            }
        ]}
>
    <div class="flex shrink-0 items-center justify-center">
        <span
                class:list={[
                    "material-icons-round text-xl sm:text-2xl",
                    { "text-white/20": !isAction, "text-sky-400/80": isAction }
                ]}
                aria-hidden="true"
        >
            {icon}
        </span>
    </div>

    <div class="flex flex-col min-w-0">
        <p
                class:list={[
                    "text-sm font-bold tracking-tight truncate",
                    { "text-white": !isAction, "text-indigo-100": isAction }
                ]}
        >
            {title}
        </p>
    </div>
</a>