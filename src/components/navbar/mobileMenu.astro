---
import MobileNavItem from "./mobileNavItem.astro";

const items = [
    {
        href: "#",
        title: "Inicio",
        description: "Vista general",
        icon: "home",
    },
    {
        href: "#features",
        title: "Funciones",
        description: "Cómo protege Vera",
        icon: "settings",
    },
    {
        href: "#newsletter",
        title: "Novedades",
        description: "Actualizaciones de Vera",
        icon: "mail",
    },
    {
        href: "#comparative",
        title: "Comparación",
        description: "Diferencias clave",
        icon: "bar_chart",
    },
];
---

<div
        id="mobile-menu"
        class="hidden border-t border-white/10 bg-(--color-bg)/95 px-6 py-6 backdrop-blur-2xl md:hidden"
>

    <div class="grid grid-cols-2 gap-4">

        {
            items.map((item) => (
                    <MobileNavItem {...item} />
            ))
        }

    </div>

</div>