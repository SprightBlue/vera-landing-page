---
import PhoneSolutionContent from "./phoneSolutionContent.astro";
---

<div class="relative flex w-full justify-center py-10 lg:py-0">

    <div class="absolute inset-0 flex items-center justify-center z-[-1] pointer-events-none">
        <div class="w-72 h-72 rounded-full bg-primary opacity-10 blur-[80px]"></div>
    </div>

    <div class="relative w-full max-w-70 rounded-[2.5rem] border border-white/10 bg-white/3 p-3 shadow-[0_20px_40px_-10px_rgba(0,0,0,0.3)] backdrop-blur-2xl">

        <div class="mb-4 flex justify-center">
            <div class="h-1.5 rounded-full bg-white/20 w-16"></div>
        </div>

        <div class="relative overflow-hidden rounded-4xl bg-[#0a0f1e] border border-white/5">
            <PhoneSolutionContent />
        </div>

        <div class="absolute inset-y-10 left-0 w-px bg-linear-to-b from-transparent via-white/10 to-transparent"></div>
    </div>

</div>