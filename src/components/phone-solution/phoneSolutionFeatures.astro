---
import PhoneSolutionItem from "./phoneSolutionItem.astro";

const flow = [
    {
        icon: "content_copy",
        title: "Recibe",
        description: "Simplemente copia el mensaje sospechoso o deja que Vera detecte la notificación entrante de forma automática."
    },
    {
        icon: "psychology",
        title: "Analiza",
        description: "Nuestro motor de IA procesa el contenido, verifica enlaces y contrasta con bases de datos de fraude globales."
    },
    {
        icon: "security",
        title: "Recomienda",
        description: "Recibes una guía clara: qué hacer, cómo bloquear y qué precauciones tomar para mantener tu seguridad."
    }
];
---

<div class="flex flex-col gap-6 w-full max-w-lg mx-auto lg:mx-0">
    {flow.map((item) => (
            <PhoneSolutionItem
                icon = {item.icon}
                title = {item.title}
                description = {item.description}
            />
    ))}
</div>