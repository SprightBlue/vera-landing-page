<section id="cta" class="relative py-24 lg:py-32 overflow-hidden">
    <div class="max-w-7xl mx-auto px-6 lg:px-12">
        <div class="relative isolate overflow-hidden rounded-[2.5rem] border border-white/10 bg-white/1 backdrop-blur-sm p-12 lg:p-24 text-center
                    before:absolute before:inset-0 before:bg-[radial-gradient(circle_at_center,rgba(59,130,246,0.06)_0%,transparent_70%)] before:pointer-events-none
                    after:absolute after:-left-10 after:top-1/2 after:-translate-y-1/2 after:w-64 after:h-125 after:border-2 after:border-white/5 after:rounded-[3rem] after:rotate-12 after:pointer-events-none after:hidden lg:after:block">

            <div class="absolute -right-20 top-1/2 -translate-y-1/2 w-137.5 h-80 border-2 border-white/5 rounded-2xl -rotate-6 pointer-events-none hidden lg:flex flex-col opacity-50">
                <div class="w-full h-8 border-b border-white/5 flex items-center px-4 gap-1.5">
                    <div class="w-1.5 h-1.5 rounded-full bg-white/5"></div>
                    <div class="w-1.5 h-1.5 rounded-full bg-white/5"></div>
                </div>
            </div>

            <div class="relative z-10 max-w-3xl mx-auto space-y-12">
                <header class="space-y-4">
                    <h2 class="text-4xl lg:text-6xl font-display font-extrabold tracking-tight text-white leading-[1.1] text-balance">
                        <span class="bg-linear-to-r from-primary to-secondary bg-clip-text text-transparent">Tu seguridad</span> no puede esperar
                    </h2>
                    <p class="text-lg lg:text-xl text-white/60 font-medium max-w-xl mx-auto text-pretty">
                        Únete a los miles de usuarios que ya protegen su vida digital con la inteligencia de Vera.
                    </p>
                </header>

                <nav class="flex flex-wrap items-center justify-center gap-6 lg:gap-8">
                    <a
                            href="javascript:void(0);"
                            id="btn-cta-google-play"
                            class="group transition-all duration-300 hover:-translate-y-1 hover:brightness-110 active:translate-y-0 outline-none"
                    >
                        <img
                                src="/badges/google-play.svg"
                                alt="Google Play"
                                width="250"
                                height="76"
                                class="w-52.5 h-16 lg:w-62.5 lg:h-19 object-contain"
                        />
                    </a>

                    <a
                            href="javascript:void(0);"
                            id="btn-cta-web-app"
                            class="group inline-flex items-center justify-center gap-4 bg-black border border-white/40 rounded-xl w-52.5 h-16 lg:w-62.5 lg:h-19 transition-all duration-300 hover:-translate-y-1 hover:border-white hover:shadow-2xl hover:shadow-primary/10 active:translate-y-0 outline-none"
                    >
                        <span class="material-icons-round text-white/80 text-[28px] lg:text-[34px]">public</span>
                        <div class="flex flex-col text-left leading-tight">
                            <span class="text-[10px] lg:text-[11px] uppercase font-bold tracking-widest text-white/50">Acceder a la</span>
                            <span class="text-[16px] lg:text-[18px] font-black uppercase text-white tracking-tight">Versión Web</span>
                        </div>
                    </a>
                </nav>
            </div>
        </div>
    </div>
</section>

<script is:inline>
    (function() {
        const track = (name) => {
            if (typeof gtag === 'function') {
                gtag('event', 'click_cta_final', { 'store_name': name });
            }
        };

        document.addEventListener('click', (e) => {
            if (e.target.closest('#btn-cta-google-play')) track('google_play_bottom');
            if (e.target.closest('#btn-cta-web-app')) track('web_version_bottom');
        });
    })();
</script>