---
interface Props {
    image: string;
    title: string;
    description: string;
    alt?: string;
}

const { image, title, description, alt = ""} = Astro.props;
---

<article class="flex flex-col bg-linear-to-br from-white/5 to-white/1 border border-white/10 rounded-3xl overflow-hidden shadow-2xl">
    <div class="relative aspect-video w-full overflow-hidden bg-white/5">
        <div class="absolute inset-0 bg-primary/10 z-10 pointer-events-none"></div>

        <img
                src={image}
                alt={alt}
                width=auto
                height=auto
                decoding="async"
                class="object-cover w-full h-full opacity-60 grayscale-20"
        />

        <div class="absolute bottom-0 left-0 w-full h-px bg-linear-to-r from-transparent via-white/20 to-transparent z-20"></div>
    </div>

    <div class="p-8 space-y-3">
        <h3 class="text-xl font-bold text-white tracking-tight leading-tight">
            {title}
        </h3>
        <p class="text-sm text-slate-400 leading-relaxed font-medium">
            {description}
        </p>
    </div>
</article>