---
import ProblemItem from "./problemItem.astro";

const problems = [
    {
        image: "/images/scam-message.jpg",
        title: "Mensajes Engañosos",
        description: "Identificamos patrones de lenguaje sospechosos en SMS y chats para prevenir intentos de phishing antes de que hagas clic."
    },
    {
        image: "/images/scam-call.jpg",
        title: "Llamadas de Riesgo",
        description: "Alertas preventivas sobre números reportados por fraude o suplantación de identidad de entidades bancarias."
    },
    {
        image: "/images/scam-link.jpg",
        title: "Enlaces Maliciosos",
        description: "Análisis en tiempo real de URLs acortadas o dominios falsos que buscan robar tus credenciales de acceso."
    }
];
---

<div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-10">
    {problems.map((problem) => (
            <ProblemItem
                    image={problem.image}
                    title={problem.title}
                    description={problem.description}
                    alt={problem.title}
            />
    ))}
</div>