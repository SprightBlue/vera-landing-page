---
const steps = [
    {
        number: "01",
        title: "Recibís un mensaje",
        description:
            "Monitorea mensajes sospechosos provenientes de SMS, redes sociales o aplicaciones de mensajería.",
    },
    {
        number: "02",
        title: "Analiza el contenido",
        description:
            "Detecta patrones de phishing, ingeniería social y enlaces potencialmente peligrosos.",
    },
    {
        number: "03",
        title: "Evalúa el riesgo",
        description:
            "Clasifica el nivel de amenaza antes de que interactúes con el mensaje.",
    },
    {
        number: "04",
        title: "Recomienda qué hacer",
        description:
            "Recibís sugerencias claras para evitar fraudes o filtraciones de información.",
    },
];
---

<section id="features" class="relative px-6 py-24 lg:px-20">

    <!-- Glow -->
    <div class="absolute left-1/2 top-1/2 h-125 w-125 -translate-x-1/2 -translate-y-1/2 rounded-full bg-indigo-500/10 blur-[120px]"></div>

    <div class="relative mx-auto max-w-7xl">

        <!-- Header -->
        <div class="mx-auto max-w-3xl text-center">

            <p class="mb-4 text-sm font-medium uppercase tracking-[0.3em] text-blue-400">
                Funciones
            </p>

            <h2 class="font-[Montserrat] text-4xl font-extrabold leading-tight md:text-5xl text-text">
                Cómo funciona vera
            </h2>

            <p class="mt-6 text-lg leading-relaxed text-text/60">
                Protección inteligente antes de que tomes una decisión riesgosa.
            </p>

        </div>

        <!-- Steps -->
        <div class="relative mt-20 grid gap-10 md:grid-cols-2 xl:grid-cols-4">

            {steps.map((step) => (
                    <div class="group relative overflow-hidden rounded-[2rem] border border-(--glass-border) bg-(--glass-bg) p-8 backdrop-blur-xl transition duration-[--transition-base] hover:-translate-y-2 hover:border-[--card-hover-border]">

                        <!-- Title row -->
                        <div class="flex items-start justify-between gap-6">

                            <h3 class="text-xl md:text-2xl font-bold text-text">
                                {step.title}
                            </h3>

                            <span class="text-5xl font-black text-white/5 leading-none">
                                {step.number}
                            </span>

                        </div>

                        <!-- Description -->
                        <p class="mt-4 leading-relaxed text-text/60">
                            {step.description}
                        </p>

                    </div>
            ))}

        </div>

    </div>

</section>