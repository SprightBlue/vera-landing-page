<section id="newsletter" class="relative overflow-hidden px-4 py-16 lg:px-20 lg:py-24">

    <!-- Glow de fondo: Reducido en móvil para que no cree scroll fantasma -->
    <div class="absolute left-1/2 top-1/2 h-64 w-64 -translate-x-1/2 -translate-y-1/2 rounded-full bg-blue-600/10 blur-3xl md:h-112.5 md:w-112.5"></div>

    <div class="relative mx-auto max-w-5xl">

        <!-- Card: Ajustamos paddings para móviles -->
        <div class="overflow-hidden rounded-[2rem] border border-white/10 bg-linear-to-br from-white/5 to-white/[0.03] p-6 backdrop-blur-xl md:rounded-[2.5rem] md:p-14">

            <!-- Grid: gap reducido en móvil -->
            <div class="grid items-center gap-10 lg:grid-cols-2 lg:gap-14">

                <!-- LEFT -->
                <div class="text-center lg:text-left">

                    <p class="mb-4 text-xs font-medium uppercase tracking-[0.3em] text-blue-400 md:text-sm">
                        Novedades
                    </p>

                    <h2 class="font-[Montserrat] text-3xl font-extrabold leading-tight text-text md:text-5xl">
                        Enterate de las novedades de vera
                    </h2>

                    <p class="mt-6 text-base leading-relaxed text-text/60 md:text-lg">
                        Recibí actualizaciones sobre nuevas funciones, mejoras y lanzamientos de la app.
                    </p>

                    <!-- FORM: Importante - w-full y gap-3 -->
                    <form
                            onsubmit="event.preventDefault()"
                            class="mt-10 flex flex-col gap-3 sm:flex-row sm:items-center lg:justify-start"
                    >
                        <!-- Eliminamos el label innecesario que puede causar saltos de línea -->
                        <input
                                type="email"
                                placeholder="tuemail@ejemplo.com"
                                class="w-full rounded-2xl border border-white/10 bg-white/5 px-5 py-4 text-text placeholder-white/30 outline-none backdrop-blur-md focus:border-blue-500/40 sm:flex-1"
                        />

                        <button
                                type="submit"
                                class="w-full rounded-2xl bg-linear-to-r from-blue-500 to-indigo-500 px-8 py-4 font-semibold text-white transition hover:scale-105 sm:w-auto"
                        >
                            Suscribirme
                        </button>

                    </form>

                    <p class="mt-4 text-[10px] text-text/40 md:text-xs">
                        Sin spam. Solo novedades importantes de la aplicación.
                    </p>

                </div>

                <!-- RIGHT -->
                <div class="relative flex justify-center">

                    <!-- Glow interno ajustable -->
                    <div class="absolute h-40 w-40 rounded-full bg-blue-600/20 blur-3xl md:h-80 md:w-80"></div>

                    <!-- Teléfono: Cambié w-full max-w-70 a w-full max-w-[280px] para control real -->
                    <div class="relative w-full max-w-[280px] rounded-[2.5rem] border border-white/10 bg-[#0b1020] p-3 shadow-2xl md:max-w-70 md:rounded-[3rem]">

                        <div class="mb-4 flex justify-center">
                            <div class="h-1.5 w-16 rounded-full bg-white/10 md:w-24"></div>
                        </div>

                        <!-- El contenido interno ahora es flexible, no rígido -->
                        <div class="flex min-h-[350px] flex-col items-center justify-center rounded-[2rem] bg-bg p-6 text-center md:min-h-130 md:rounded-[2.5rem] md:p-8">

                            <img src="/logo.png" alt="vera" class="w-20 md:w-28" />

                            <h3 class="mt-6 bg-linear-to-r from-blue-500 to-indigo-500 bg-clip-text text-3xl font-bold text-transparent md:mt-8 md:text-4xl">
                                vera
                            </h3>

                            <p class="mt-4 text-xs leading-relaxed text-text/60 md:text-sm">
                                Mantente al día con la evolución de la app.
                            </p>

                            <div class="mt-8 rounded-xl border border-green-500/20 bg-green-500/10 px-4 py-3 md:mt-10 md:rounded-2xl md:px-5 md:py-4">
                                <p class="flex items-center justify-center gap-2 text-[12px] text-green-300 md:text-sm">
                                    <span class="material-icons-round text-base">check_circle</span>
                                    Actualizaciones activas
                                </p>
                            </div>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

</section>