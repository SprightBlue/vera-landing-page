---
import WebSolutionMockup from "./webSolutionMockup.astro";
import WebSolutionFeatures from "./webSolutionFeatures.astro";
---

<section class="py-16 lg:py-24 relative overflow-hidden bg-transparent">
    <div class="w-full max-w-7xl mx-auto px-6 lg:px-12 box-border">

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-center">

            <div class="lg:col-span-7 order-2 lg:order-1">
                <WebSolutionMockup />
            </div>

            <div class="lg:col-span-5 space-y-8 order-1 lg:order-2 text-center lg:text-left">
                <div class="space-y-4">
                    <h2 class="text-4xl lg:text-5xl font-display font-extrabold leading-tight tracking-tight text-white">
                        Funciones <span class="bg-linear-to-r from-primary to-secondary bg-clip-text text-transparent inline-block">Premium</span>
                    </h2>
                    <p class="text-lg text-white/70 leading-relaxed text-pretty">
                        Vera Pro extiende su protección a todas tus vías de comunicación. Un solo centro de control para tu tranquilidad digital.
                    </p>
                </div>

                <WebSolutionFeatures />
            </div>

        </div>
    </div>
</section>