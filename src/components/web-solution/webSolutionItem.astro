---
interface Props {
    icon: string;
    title: string;
    description: string;
}

const { icon, title, description } = Astro.props;
---

<div class="w-full box-border">
    <div class="p-4 rounded-2xl bg-white/4 border border-white/10 w-full text-left">
        <div class="flex items-start gap-4">

            <div class="shrink-0 w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center border border-primary/20">
                <span class="material-icons-round text-primary text-[20px]" aria-hidden="true">
                    {icon}
                </span>
            </div>

            <div class="space-y-1">
                <h3 class="text-white font-bold text-base leading-tight tracking-tight">
                    {title}
                </h3>
                <p class="text-xs text-white/50 leading-relaxed font-medium text-pretty">
                    {description}
                </p>
            </div>
        </div>
    </div>
</div>