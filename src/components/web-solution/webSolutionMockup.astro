---
import WebSolutionContent from "./webSolutionContent.astro";
---

<div class="relative w-full">

    <div class="relative z-10 w-full rounded-xl border border-white/10 bg-[#0a0f1e] shadow-2xl overflow-hidden">

        <div class="h-8 bg-white/3 border-b border-white/5 flex items-center px-4 gap-1.5">
            <div class="w-2.5 h-2.5 rounded-full bg-red-500/20 border border-red-500/30"></div>
            <div class="w-2.5 h-2.5 rounded-full bg-orange-500/20 border border-orange-500/30"></div>
            <div class="w-2.5 h-2.5 rounded-full bg-green-500/20 border border-green-500/30"></div>
        </div>

        <div class="w-full bg-bg">
            <WebSolutionContent />
        </div>

    </div>

</div>