---
import WebSolutionContent from "./webSolutionContent.astro";
---

<div class="relative w-full group">
    <div class="absolute -inset-4 bg-primary/10 blur-[100px] rounded-full z-0 pointer-events-none"></div>

    <div class="relative z-10 w-full rounded-xl border border-white/10 bg-bg shadow-[0_32px_64px_-16px_rgba(0,0,0,0.6)] overflow-hidden">

        <div class="h-8 bg-white/5 border-b border-white/5 flex items-center px-4 gap-1.5">
            <div class="w-2.5 h-2.5 rounded-full bg-red-500/20 border border-red-500/30"></div>
            <div class="w-2.5 h-2.5 rounded-full bg-orange-500/20 border border-orange-500/30"></div>
            <div class="w-2.5 h-2.5 rounded-full bg-green-500/20 border border-green-500/30"></div>
        </div>

        <div class="w-full">
            <WebSolutionContent />
        </div>

    </div>

    <div class="absolute -bottom-10 left-1/2 -translate-x-1/2 w-4/5 h-10 bg-primary/5 blur-3xl z-0"></div>
</div>