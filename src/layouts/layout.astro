---
import "../styles/global.css";

const { title } = Astro.props;
---

<!doctype html>
<html lang="es" class="dark">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />

    <title>{title}</title>

    <link rel="icon" type="image/png" href="/logo.png" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />

    <link
            href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Montserrat:wght@700;800&display=swap"
            rel="stylesheet"
    />

    <link
            href="https://fonts.googleapis.com/icon?family=Material+Icons+Round"
            rel="stylesheet"
    />

    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-10PDLBF5S9"></script>

    <script is:inline>
        window.dataLayer = window.dataLayer || [];

        function gtag(...args) {
            window.dataLayer.push(args);
        }

        gtag('js', new Date());

        gtag('config', 'G-10PDLBF5S9');
    </script>
</head>

<body>
<slot />
</body>
</html>