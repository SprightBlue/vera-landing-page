---
import "../styles/global.css";

interface Props {
    title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es" class="dark">
<head>
    <meta charset="UTF-8" />
    <meta name="description" content="Vera - Tu asistente inteligente contra estafas digitales y phishing." />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{title} | Vera</title>

    <link rel="icon" type="image/png" href="/brand/isologo-vera.png" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
            href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Montserrat:wght@700;800&display=swap"
            rel="stylesheet"
    />
    <link
            href="https://fonts.googleapis.com/icon?family=Material+Icons+Round"
            rel="stylesheet"
    />

    <script async src="https://www.googletagmanager.com/gtag/js?id=G-10PDLBF5S9"></script>
    <script is:inline>
        window.dataLayer = window.dataLayer || [];
        function gtag() { dataLayer.push(arguments); }
        gtag('js', new Date());
        gtag('config', 'G-10PDLBF5S9');
    </script>
</head>

<body class="selection:bg-accent selection:text-white">
<slot />
</body>
</html>